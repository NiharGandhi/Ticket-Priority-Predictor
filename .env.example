# ──────────────────────────────────────────────────────────
# Ticket Priority Predictor — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit the actual .env file to version control.
# ──────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
# Port the Express backend listens on
PORT=5000

# Node environment: development | production | test
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
# Full MongoDB connection URI
# For Docker Compose use: mongodb://admin:changeme@mongodb:27017/ticket_predictor?authSource=admin
# For MongoDB Atlas use:  mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
MONGO_URI=mongodb://localhost:27017/ticket_predictor

# MongoDB root credentials (used by docker-compose only)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_DB_NAME=ticket_predictor

# ── Authentication (JWT) ───────────────────────────────────
# Strong random secret — generate with: openssl rand -base64 64
JWT_SECRET=replace_with_a_very_long_random_secret_string

# Token expiry duration (e.g. 7d, 24h, 3600)
JWT_EXPIRE=7d

# ── ML Prediction Service ─────────────────────────────────
# Base URL of the external ML API used by backend/utils/mlPredict.js
# Leave blank to disable ML predictions
ML_API_URL=https://your-ml-service.example.com

# API key / bearer token for the ML service (if required)
ML_API_KEY=

# ── CORS / Client Origin ──────────────────────────────────
# URL of the frontend — used for CORS allow-list
# In production this should be your public domain
CLIENT_URL=http://localhost:5173

# ── Frontend (Vite build-time variables) ──────────────────
# Base URL that the React app uses to call the backend API
# Must start with VITE_ to be exposed to the browser bundle
VITE_API_BASE_URL=http://localhost:5000/api
